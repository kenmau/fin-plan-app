{
  "name": "backend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/backend/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/backend",
        "main": "packages/backend/src/server.ts",
        "tsConfig": "packages/backend/tsconfig.json"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "backend:build"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "configFile": "packages/backend/vitest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/backend"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/backend/**/*.ts"]
      }
    },
    "db-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit generate",
        "cwd": "packages/backend"
      }
    },
    "db-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "drizzle-kit migrate",
        "cwd": "packages/backend"
      }
    },
    "db-seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/db/seed-runner.ts",
        "cwd": "packages/backend"
      }
    }
  },
  "tags": ["type:app", "scope:backend"]
}
