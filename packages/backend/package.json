{
  "name": "@finplan/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node ../../dist/packages/backend/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed-runner.ts"
  },
  "dependencies": {
    "tslib": "^2.6.0",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@finplan/shared": "*",
    "bcrypt": "^5.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.35.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "postgres": "^3.4.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.26.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "~5.5.0",
    "vitest": "^2.0.0"
  }
}
