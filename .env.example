# =========================================================
# FinPlan — Environment Variables
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =========================================================

# ---------------------
# Database
# ---------------------
DATABASE_URL=postgresql://finplan:finplan@localhost:5432/finplan

# Test database (separate DB for integration tests)
TEST_DATABASE_URL=postgresql://finplan:finplan@localhost:5432/finplan_test

# ---------------------
# JWT Authentication
# ---------------------
# Generate a secure secret: node -e "require('crypto').randomBytes(64).toString('hex').then(console.log)"
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ---------------------
# Server
# ---------------------
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ---------------------
# CORS (frontend origin)
# ---------------------
CORS_ORIGIN=http://localhost:5173

# ---------------------
# Seed Script (bcrypt hashes of user passwords)
# Generate: node -e "require('bcrypt').hash('yourpassword', 12).then(console.log)"
# ---------------------
KEN_PASSWORD_HASH=$2b$12$examplehashforken...
LAN_PASSWORD_HASH=$2b$12$examplehashforlan...
